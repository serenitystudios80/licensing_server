# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Config::load() requires every key below to be present and non-empty.

# --- Database connection ---------------------------------------------------
DB_HOST=localhost
DB_NAME=license_server
DB_USER=license_server_user
DB_PASS=change-me-to-a-strong-password

# --- Razorpay integration ---------------------------------------------------
# Public key ID from the Razorpay dashboard (identifies your Razorpay account).
RAZORPAY_KEY_ID=rzp_test_1234567890abcd
# Secret used to verify the signature of incoming Razorpay webhook payloads.
RAZORPAY_WEBHOOK_SECRET=change-me-razorpay-webhook-secret

# --- HMAC signing -------------------------------------------------------
# Shared secret used to sign/verify HMAC signatures for license API requests.
HMAC_SHARED_SECRET=change-me-to-a-long-random-string

# --- Trusted proxies ---------------------------------------------------
# Comma-separated CIDR list of trusted reverse-proxy IP ranges (e.g.
# Cloudflare's published IP ranges) used to determine the real client IP
# from X-Forwarded-For / CF-Connecting-IP headers.
TRUSTED_PROXY_RANGES=173.245.48.0/20,103.21.244.0/22

# --- Rate limiting -------------------------------------------------------
# Max requests allowed per source IP within the window below.
RATE_LIMIT_IP_MAX=60
RATE_LIMIT_IP_WINDOW_SECONDS=60
# Max requests allowed per license key within the window below.
RATE_LIMIT_KEY_MAX=30
RATE_LIMIT_KEY_WINDOW_SECONDS=60

# --- Admin session -------------------------------------------------------
# Secret used to sign/encrypt admin session cookies.
SESSION_SECRET=change-me-to-a-long-random-string
